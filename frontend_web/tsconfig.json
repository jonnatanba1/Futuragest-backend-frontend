{
  "extends": "@futuragest/tsconfig/react",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@futuragest/contracts": ["../packages/contracts/src/index.ts"],
      "@futuragest/contracts/generated/api": ["../packages/contracts/src/generated/api.ts"]
    },
