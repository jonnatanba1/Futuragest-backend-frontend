# Local-only dev file: pnpm-workspace.yaml carries the pnpm 11+ build-script
# approval (allowBuilds) used on dev machines. The Dockerfile pins pnpm@9, which
# REQUIRES a `packages:` field in any pnpm-workspace.yaml and aborts `pnpm run
# build` with "packages field missing or empty" if it sees this file. pnpm 9
# doesn't need build-script approval, so keep it out of the build context.
pnpm-workspace.yaml

# Standard excludes — never needed in the build context.
node_modules
.git
dist
