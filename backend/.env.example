# FuturaGest API — environment variables template
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit it or the secrets/ directory.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (dev DB)
DATABASE_URL=postgresql://futuragest:CHANGE_ME@localhost:5432/futuragest_dev

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=futuragest

# ── Firebase Cloud Messaging (push notifications) ───────────────────────────
# Set FIREBASE_ENABLED=true to activate real FCM sends via FcmNotificationAdapter.
# When false (or unset), NoOpNotificationAdapter is used (structured log only).
FIREBASE_ENABLED=false

# Path to the Firebase service-account JSON file (preferred over inline JSON).
# The file lives in backend/secrets/ which is gitignored — never commit it.
# Download it from Firebase Console -> Project Settings -> Service Accounts.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Alternative: inline the service-account JSON as a single-line string.
# Used as fallback when FIREBASE_SERVICE_ACCOUNT_PATH is not set.
# FIREBASE_SERVICE_ACCOUNT_JSON={type:service_account,project_id:...}

# Optional: also send push notifications to SYSTEM_ADMIN users (default: false).
# PUSH_NOTIFY_SYSTEM_ADMIN=false
