{
  "name": "@futuragest/api",
  "version": "0.0.1",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "jest",
    "test:unit": "jest --testPathPattern='\\.spec\\.ts$'",
    "test:int": "jest --runInBand --testPathPattern='\\.int-spec\\.ts$'",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main",
    "start:dev": "ts-node-dev -r tsconfig-paths/register src/main.ts",
    "generate:openapi": "cross-env GENERATE_OPENAPI=true ts-node -r tsconfig-paths/register src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.17",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.17",
    "@nestjs/swagger": "^8.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "firebase-admin": "^13.10.0",
    "minio": "^8.0.7",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@futuragest/tsconfig": "workspace:*",
    "@nestjs/testing": "^10.4.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
