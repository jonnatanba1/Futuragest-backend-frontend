// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SYSTEM_ADMIN
  GERENCIA
  TALENTO_HUMANO
  LIDER_OPERATIVO
  COORDINADOR
  SUPERVISOR
}

enum SupervisorArea {
  BARRIDO
  RECOLECCION
  SUPERNUMERARIO
}

enum NovedadStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TipoNovedad {
  LLEGADA_TARDE
  HORAS_EXTRA
}

// ---------------------------------------------------------------------------
// Org domain
// ---------------------------------------------------------------------------

/// Geographic zone (e.g. Zona Urabá, Zona Bajo Cauca).
/// Montería is the central office and operates with global scope (no zone).
model Zone {
  id              String          @id @default(uuid())
  name            String          @unique
  municipios      Municipio[]
  supervisors     Supervisor[]
  /// One COORDINADOR per zone (enforced by @unique on User.coordinatedZoneId)
  coordinador     User?           @relation("ZoneCoordinador")
  jornadaPolicies JornadaPolicy[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
}

/// Municipality belonging to a zone.
model Municipio {
  id          String       @id @default(uuid())
  name        String
  zoneId      String
  zone        Zone         @relation(fields: [zoneId], references: [id])
  supervisors Supervisor[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  @@unique([zoneId, name])
}

// ---------------------------------------------------------------------------
// Identity domain
// ---------------------------------------------------------------------------

/// Application user. One row per human actor.
model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String
  role              Role
  mustChangePassword Boolean       @default(true)
  /// Set only for COORDINADOR. @unique enforces one coordinador per zone.
  coordinatedZoneId String?        @unique
  coordinatedZone   Zone?          @relation("ZoneCoordinador", fields: [coordinatedZoneId], references: [id])
  supervisor        Supervisor?
  sessions          DeviceSession[]
  approvedNovedades Novedad[]      @relation("NovedadApprover")
  /// Compensation periods this user approved (TALENTO_HUMANO / SYSTEM_ADMIN)
  compensationPeriodsApproved CompensationPeriod[] @relation("CompensationApprover")
  createdAt         DateTime       @default(now())
}

/// Supervisor entity — linked to a User, scoped to a zone + municipio.
model Supervisor {
  id           String         @id @default(uuid())
  userId       String         @unique
  user         User           @relation(fields: [userId], references: [id])
  municipioId  String
  municipio    Municipio      @relation(fields: [municipioId], references: [id])
  /// Denormalized zone for efficient scope filtering
  zoneId       String
  zone         Zone           @relation(fields: [zoneId], references: [id])
  area         SupervisorArea
  operarios    Operario[]
  assignments  Assignment[]
  attendances  Attendance[]
  novedades    Novedad[]
  createdAt    DateTime       @default(now())
}

/// Field operario (worker assigned to a supervisor).
model Operario {
  id            String       @id @default(uuid())
  fullName      String
  /// National document number — must be unique across all operarios
  documento     String       @unique
  /// Current supervisor (scope key → zone via supervisor.zoneId)
  supervisorId  String
  supervisor    Supervisor   @relation(fields: [supervisorId], references: [id])
  /// Free-text job position (e.g. "Barrido", "Recolección"). Defaults to empty string.
  cargo         String       @default("")
  assignments   Assignment[]
  attendances   Attendance[]
  compensationPeriods CompensationPeriod[]
  compensatoryRests   CompensatoryRest[]
  jornadaPolicies     JornadaPolicy[]
  /// Soft-deactivation timestamp. null = active; non-null = deactivated.
  deactivatedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt

  @@index([updatedAt])
}

/// Operario ↔ Supervisor assignment record (reassignable, end-dated).
model Assignment {
  id           String     @id @default(uuid())
  operarioId   String
  operario     Operario   @relation(fields: [operarioId], references: [id])
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id])
  /// Denormalized zone for efficient scope queries
  zoneId       String
  startDate    DateTime   @default(now())
  /// NULL = currently active assignment
  endDate      DateTime?
  createdAt    DateTime   @default(now())
}

// ---------------------------------------------------------------------------
// Attendance domain
// ---------------------------------------------------------------------------

/// Attendance record — one per operario per Colombia calendar day.
/// Created on check-in; completed (locked) on check-out.
model Attendance {
  id                  String     @id @default(uuid())
  supervisorId        String
  supervisor          Supervisor @relation(fields: [supervisorId], references: [id])
  operarioId          String
  operario            Operario   @relation(fields: [operarioId], references: [id])
  /// Denormalized zone for O(1) COORDINADOR scope filtering (same pattern as Assignment)
  zoneId              String
  date                String     // YYYY-MM-DD, client-computed Colombia local
  checkInCapturedAt   DateTime   // client device clock
  checkInReceivedAt   DateTime   @default(now()) // server clock
  checkInLat          Float
  checkInLng          Float
  checkInAccuracy     Float?
  checkOutCapturedAt  DateTime?
  checkOutReceivedAt  DateTime?
  checkOutLat         Float?
  checkOutLng         Float?
  checkOutAccuracy    Float?
  checkInPhotoKey     String?    // MinIO object key for INGRESO (check-in) photo; null until uploaded
  checkOutPhotoKey    String?    // MinIO object key for SALIDA (check-out) photo; null until uploaded
  /// Audit label: how the supervisor verified identity at check-in. Null = legacy / old app version.
  /// AUDIT LABEL ONLY — no authorization logic may depend on this field.
  checkInVerification  VerificationMethod?
  /// Audit label: how the supervisor verified identity at check-out. Null = legacy / old app version.
  /// AUDIT LABEL ONLY — no authorization logic may depend on this field.
  checkOutVerification VerificationMethod?
  clientRef           String     @unique // client idempotency token (required)
  checkOutClientRef   String?    // optional checkout idempotency token (not globally unique)
  completedAt         DateTime?  // non-null = record locked/immutable
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  novedades           Novedad[]
  breakdown           AttendanceBreakdown?
  compensatoryRest    CompensatoryRest?

  @@unique([operarioId, date])
  @@index([supervisorId])
  @@index([operarioId])
  @@index([zoneId])
  @@index([date])
  @@index([updatedAt])
}

// ---------------------------------------------------------------------------
// Novedad domain (overtime novelty + approval)
// ---------------------------------------------------------------------------

/// Overtime / late-arrival novelty record — one ACTIVE (PENDING|APPROVED) per attendance enforced
/// by a partial unique index hand-authored in the migration SQL.
/// REJECTED rows do not count toward the limit (partial unique excludes them).
model Novedad {
  id               String        @id @default(uuid())
  attendanceId     String
  attendance       Attendance    @relation(fields: [attendanceId], references: [id])
  /// Denormalized creator — scope key for SUPERVISOR filter
  supervisorId     String
  supervisor       Supervisor    @relation(fields: [supervisorId], references: [id])
  /// Denormalized zone — scope key for COORDINADOR filter
  zoneId           String
  /// Type of novelty — LLEGADA_TARDE (auto-generated) or HORAS_EXTRA (supervisor-requested)
  tipoNovedad      TipoNovedad   @default(HORAS_EXTRA)
  horasExtra       Decimal       @db.Decimal(5, 2)
  tipoHoraExtra    TipoHoraExtra?
  /// Only set when tipoNovedad = LLEGADA_TARDE
  minutosTarde     Int?
  /// true = system-created (late arrival); false = supervisor-requested
  autoGenerada     Boolean       @default(false)
  motivo           String?
  status           NovedadStatus @default(PENDING)
  clientRef        String?       @unique // optional idempotency token for offline sync
  approvedByUserId String?
  approvedBy       User?         @relation("NovedadApprover", fields: [approvedByUserId], references: [id])
  decidedAt        DateTime?
  /// Audit label: how the líder operativo verified identity when approving/rejecting.
  /// Null = web admin decision (no biometrics) or legacy row.
  /// AUDIT LABEL ONLY — no authorization logic may depend on this field.
  decisionVerification VerificationMethod?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // No @@unique([attendanceId]) — partial unique index added by hand in migration:
  // CREATE UNIQUE INDEX "Novedad_attendanceId_active_key"
  //   ON "Novedad"("attendanceId")
  //   WHERE status IN ('PENDING', 'APPROVED');
  @@index([supervisorId])
  @@index([zoneId])
  @@index([status])
  @@index([updatedAt])
}

// ---------------------------------------------------------------------------
// Compensacion de Horas domain — PR-A
// ---------------------------------------------------------------------------

/// Company-wide effective-dated work-day baseline (append-only).
/// Lowering the journey = INSERT a new row with a future vigenteDesde — NEVER UPDATE.
/// Resolving jornadaDelDia: latest JornadaPolicy with vigenteDesde <= attendance.date.
///
/// Scope hierarchy (3-level):
///   1. operarioId → per-worker override (highest priority)
///   2. zoneId      → per-zone default
///   3. null/null   → global default (lowest priority)
model JornadaPolicy {
  id              String    @id @default(uuid())

  // ── Scope (jerárquico: operario → zona → global) ──
  operarioId      String?   // null = no per-operario override
  operario        Operario? @relation(fields: [operarioId], references: [id])
  zoneId          String?   // null = no per-zone override (combined with operarioId null = global)
  zone            Zone?     @relation(fields: [zoneId], references: [id])

  // ── Horario ──
  horaInicio      String    // "07:00" (HH:mm, hora Colombia UTC-5)
  horaFin         String    // "17:00"
  diasLaborales   Int[]     // ISO weekday: [1,2,3,4,5] = Lun-Vie

  // ── Almuerzo ──
  almuerzoInicio  String?   // null = auto-calculated at shift midpoint
  almuerzoFin     String?   // null = auto (almuerzoInicio + 60 min)

  // ── Desayuno ──
  desayunoInicio  String?   // null = auto-calculated (horaInicio + 2h)
  desayunoFin     String?   // null = auto (desayunoInicio + 30 min)

  // ── Tolerancia ──
  toleranciaMin   Int       @default(5) // late arrival tolerance in minutes

  // ── Horas ──
  horasDiarias    Decimal   @db.Decimal(4, 2)
  horasSemanales  Decimal   @db.Decimal(4, 2)

  // ── Vigencia ──
  vigenteDesde    DateTime
  createdAt       DateTime  @default(now())

  // ── Relations ──
  breakdowns      AttendanceBreakdown[]

  @@unique([operarioId, zoneId, vigenteDesde])
  @@index([vigenteDesde])
  @@index([zoneId])
  @@index([operarioId])
}

// ---------------------------------------------------------------------------
// Compensacion de Horas domain — PR-B
// ---------------------------------------------------------------------------

/// Disposition decision when closing a negative-balance period.
/// CARRY_OVER  = roll negative saldo into next period's carryIn.
/// PAYROLL_DEDUCTION = deduct from payroll (debt settled; NOT carried forward).
/// Biometric verification method used by the supervisor (check-in/check-out)
/// or líder operativo (novedad approve/reject).
/// AUDIT LABEL ONLY — no authorization logic may depend on this field.
/// BIOMETRIC         = fingerprint or face verification succeeded.
/// DEVICE_CREDENTIAL = PIN/pattern/password used (no biometric).
/// NONE              = device could not verify / bypass (client reports unsupported hardware).
enum VerificationMethod {
  BIOMETRIC
  DEVICE_CREDENTIAL
  NONE
}

enum CompensationDisposition {
  CARRY_OVER
  PAYROLL_DEDUCTION
}

/// Immutable snapshot of a closed fortnight balance.
/// Written ONCE at fortnight close — never updated. Mirror of Attendance.completedAt immutability.
/// Uniqueness: one period per operario+periodKey enforced by a partial unique index
/// hand-authored in the migration SQL (Novedad pattern).
model CompensationPeriod {
  id               String                  @id @default(uuid())
  operarioId       String
  operario         Operario                @relation(fields: [operarioId], references: [id])
  /// Denormalized zone for COORDINADOR scope filtering (same pattern as Attendance.zoneId)
  zoneId           String
  /// Denormalized supervisor for SUPERVISOR scope filtering
  supervisorId     String
  /// Canonical fortnight id: "YYYY-MM-Q1" (days 1-15) | "YYYY-MM-Q2" (days 16-end)
  periodKey        String
  desde            String                  // YYYY-MM-DD Colombia local (inclusive)
  hasta            String                  // YYYY-MM-DD Colombia local (inclusive)
  creditos         Decimal                 @db.Decimal(7, 2) // Σ positive deltas
  debitos          Decimal                 @db.Decimal(7, 2) // Σ |negative deltas|
  carryIn          Decimal                 @db.Decimal(7, 2) // negative saldo from previous CARRY_OVER (≤ 0)
  
  // ── Desglose de horas (nullable para períodos pre-migración) ──
  horasOrdinariasDiurnas    Decimal?       @db.Decimal(7, 2)
  horasOrdinariasNocturnas  Decimal?       @db.Decimal(7, 2)
  horasExtraDiurnas         Decimal?       @db.Decimal(7, 2)
  horasExtraNocturnas       Decimal?       @db.Decimal(7, 2)
  horasDominicalesFestivas  Decimal?       @db.Decimal(7, 2)

  // ── Valor monetario ──
  valorRecargos             Decimal?       @db.Decimal(12, 2)
  tasaDominicalAplicada     Decimal?       @db.Decimal(5, 2) // Snapshot
  saldo            Decimal                 @db.Decimal(7, 2) // carryIn + creditos - debitos
  disposition      CompensationDisposition?                  // null until decided at close
  approvedByUserId String?                                   // who decided (audit trail)
  approvedBy       User?                   @relation("CompensationApprover", fields: [approvedByUserId], references: [id])
  decidedAt        DateTime?
  closedAt         DateTime                @default(now())   // immutability lock (mirrors completedAt)
  clientRef        String?                 @unique           // idempotency token for close replay
  /// Set once when HR confirms the payout. Immutable after set (guarded UPDATE WHERE paidAt IS NULL).
  paidAt           DateTime?
  /// Server-generated UUID set alongside paidAt — idempotency key for confirm-payout calls.
  payoutRef        String?
  /// Set when attendance data changes inside an already-closed period (snapshot diverged from live data).
  divergedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // Unique constraint mirrors the hand-authored migration index exactly.
  // map: name must match the existing DB index so prisma migrate dev generates NO new migration.
  @@unique([operarioId, periodKey], map: "CompensationPeriod_operario_period_key")
  @@index([operarioId])
  @@index([zoneId])
  @@index([supervisorId])
  @@index([periodKey])
}

/// Device session for soft revocation and refresh token storage.
model DeviceSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  /// Client-provided stable device identifier
  deviceId         String
  deviceLabel      String?
  /// Argon2-hashed refresh token — never plaintext
  refreshTokenHash String
  /// Non-null = revoked (soft revoke preserves audit trail)
  revokedAt        DateTime?
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  /// FCM / APNs push token. Null = device not registered for push notifications.
  pushToken    String?
  /// Device platform hint: "android" | "ios" | "web". Null = unspecified.
  pushPlatform String?

  /// Re-registration of the same device upserts on this key
  @@unique([userId, deviceId])
}

// ---------------------------------------------------------------------------
// Labor Law & Compliance Domain (Phase 1)
// ---------------------------------------------------------------------------

enum TipoHoraExtra {
  EXTRA_DIURNA
  EXTRA_NOCTURNA
  DOMINICAL_FESTIVA_DIURNA
  DOMINICAL_FESTIVA_NOCTURNA
}

model Holiday {
  id          String      @id @default(uuid())
  date        String      // "YYYY-MM-DD"
  name        String      // "Día de la Independencia"
  type        HolidayType
  year        Int
  isManual    Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@unique([date])
  @@index([year])
}

enum HolidayType {
  FIXED
  EMILIANI
  EASTER_BASED
  MANUAL
}

model SurchargeRate {
  id              String            @id @default(uuid())
  category        SurchargeCategory
  percentage      Decimal           @db.Decimal(5, 2)
  vigenteDesde    DateTime
  creadoPor       String?
  legalRef        String?
  createdAt       DateTime          @default(now())

  @@unique([category, vigenteDesde])
  @@index([category])
  @@index([vigenteDesde])
}

enum SurchargeCategory {
  RECARGO_NOCTURNO
  HORA_EXTRA_DIURNA
  HORA_EXTRA_NOCTURNA
  RECARGO_DOMINICAL_FESTIVO
}

model AttendanceBreakdown {
  id              String      @id @default(uuid())
  attendanceId    String      @unique
  attendance      Attendance  @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  horasOrdinariasDiurnas    Decimal @db.Decimal(5, 2) @default(0)
  horasOrdinariasNocturnas  Decimal @db.Decimal(5, 2) @default(0)
  horasExtraDiurnas         Decimal @db.Decimal(5, 2) @default(0)
  horasExtraNocturnas       Decimal @db.Decimal(5, 2) @default(0)
  totalHoras                Decimal @db.Decimal(5, 2) @default(0)

  esDominical     Boolean @default(false)
  esFestivo       Boolean @default(false)
  esDiaLaboral    Boolean @default(true)

  jornadaPolicyId String
  jornadaPolicy   JornadaPolicy @relation(fields: [jornadaPolicyId], references: [id])
  horaInicioAplicada  String
  horaFinAplicada     String
  horasDiariasAplicada Decimal @db.Decimal(4, 2)

  classifiedAt    DateTime @default(now())
  recalculatedAt  DateTime?
  version         Int      @default(1)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([attendanceId])
}

model CompensatoryRest {
  id                String              @id @default(uuid())
  operarioId        String
  operario          Operario            @relation(fields: [operarioId], references: [id])
  attendanceId      String              @unique
  attendance        Attendance          @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  month             String              // "YYYY-MM"
  type              CompensatoryType
  status            CompensatoryStatus  @default(PENDING)
  scheduledDate     String?
  takenDate         String?
  resolvedAt        DateTime?
  resolvedByUserId  String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([operarioId, month])
  @@index([status])
}

enum CompensatoryType {
  OCCASIONAL
  HABITUAL
}

enum CompensatoryStatus {
  PENDING
  PAID_ONLY
  SCHEDULED
  TAKEN
}
