// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SYSTEM_ADMIN
  GERENCIA
  TALENTO_HUMANO
  LIDER_OPERATIVO
  COORDINADOR
  SUPERVISOR
}

enum SupervisorArea {
  BARRIDO
  RECOLECCION
  SUPERNUMERARIO
}

enum NovedadStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Org domain
// ---------------------------------------------------------------------------

/// Geographic zone (e.g. Zona Urabá, Zona Bajo Cauca).
/// Montería is the central office and operates with global scope (no zone).
model Zone {
  id          String       @id @default(uuid())
  name        String       @unique
  municipios  Municipio[]
  supervisors Supervisor[]
  /// One COORDINADOR per zone (enforced by @unique on User.coordinatedZoneId)
  coordinador User?        @relation("ZoneCoordinador")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
}

/// Municipality belonging to a zone.
model Municipio {
  id          String       @id @default(uuid())
  name        String
  zoneId      String
  zone        Zone         @relation(fields: [zoneId], references: [id])
  supervisors Supervisor[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  @@unique([zoneId, name])
}

// ---------------------------------------------------------------------------
// Identity domain
// ---------------------------------------------------------------------------

/// Application user. One row per human actor.
model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String
  role              Role
  mustChangePassword Boolean       @default(true)
  /// Set only for COORDINADOR. @unique enforces one coordinador per zone.
  coordinatedZoneId String?        @unique
  coordinatedZone   Zone?          @relation("ZoneCoordinador", fields: [coordinatedZoneId], references: [id])
  supervisor        Supervisor?
  sessions          DeviceSession[]
  approvedNovedades Novedad[]      @relation("NovedadApprover")
  /// Compensation periods this user approved (TALENTO_HUMANO / SYSTEM_ADMIN)
  compensationPeriodsApproved CompensationPeriod[] @relation("CompensationApprover")
  createdAt         DateTime       @default(now())
}

/// Supervisor entity — linked to a User, scoped to a zone + municipio.
model Supervisor {
  id           String         @id @default(uuid())
  userId       String         @unique
  user         User           @relation(fields: [userId], references: [id])
  municipioId  String
  municipio    Municipio      @relation(fields: [municipioId], references: [id])
  /// Denormalized zone for efficient scope filtering
  zoneId       String
  zone         Zone           @relation(fields: [zoneId], references: [id])
  area         SupervisorArea
  operarios    Operario[]
  assignments  Assignment[]
  attendances  Attendance[]
  novedades    Novedad[]
  createdAt    DateTime       @default(now())
}

/// Field operario (worker assigned to a supervisor).
model Operario {
  id            String       @id @default(uuid())
  fullName      String
  /// National document number — must be unique across all operarios
  documento     String       @unique
  /// Current supervisor (scope key → zone via supervisor.zoneId)
  supervisorId  String
  supervisor    Supervisor   @relation(fields: [supervisorId], references: [id])
  assignments   Assignment[]
  attendances   Attendance[]
  compensationPeriods CompensationPeriod[]
  /// Soft-deactivation timestamp. null = active; non-null = deactivated.
  deactivatedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt

  @@index([updatedAt])
}

/// Operario ↔ Supervisor assignment record (reassignable, end-dated).
model Assignment {
  id           String     @id @default(uuid())
  operarioId   String
  operario     Operario   @relation(fields: [operarioId], references: [id])
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id])
  /// Denormalized zone for efficient scope queries
  zoneId       String
  startDate    DateTime   @default(now())
  /// NULL = currently active assignment
  endDate      DateTime?
  createdAt    DateTime   @default(now())
}

// ---------------------------------------------------------------------------
// Attendance domain
// ---------------------------------------------------------------------------

/// Attendance record — one per operario per Colombia calendar day.
/// Created on check-in; completed (locked) on check-out.
model Attendance {
  id                  String     @id @default(uuid())
  supervisorId        String
  supervisor          Supervisor @relation(fields: [supervisorId], references: [id])
  operarioId          String
  operario            Operario   @relation(fields: [operarioId], references: [id])
  /// Denormalized zone for O(1) COORDINADOR scope filtering (same pattern as Assignment)
  zoneId              String
  date                String     // YYYY-MM-DD, client-computed Colombia local
  checkInCapturedAt   DateTime   // client device clock
  checkInReceivedAt   DateTime   @default(now()) // server clock
  checkInLat          Float
  checkInLng          Float
  checkInAccuracy     Float?
  checkOutCapturedAt  DateTime?
  checkOutReceivedAt  DateTime?
  checkOutLat         Float?
  checkOutLng         Float?
  checkOutAccuracy    Float?
  signatureKey        String?    // MinIO object key for INGRESO (check-in) signature; null until uploaded
  checkOutSignatureKey String?   // MinIO object key for SALIDA (check-out) signature; null until uploaded
  clientRef           String     @unique // client idempotency token (required)
  checkOutClientRef   String?    // optional checkout idempotency token (not globally unique)
  completedAt         DateTime?  // non-null = record locked/immutable
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  novedades           Novedad[]

  @@unique([operarioId, date])
  @@index([supervisorId])
  @@index([operarioId])
  @@index([zoneId])
  @@index([date])
  @@index([updatedAt])
}

// ---------------------------------------------------------------------------
// Novedad domain (overtime novelty + approval)
// ---------------------------------------------------------------------------

/// Overtime novelty record — one ACTIVE (PENDING|APPROVED) per attendance enforced
/// by a partial unique index hand-authored in the migration SQL.
/// REJECTED rows do not count toward the limit (partial unique excludes them).
model Novedad {
  id               String        @id @default(uuid())
  attendanceId     String
  attendance       Attendance    @relation(fields: [attendanceId], references: [id])
  /// Denormalized creator — scope key for SUPERVISOR filter
  supervisorId     String
  supervisor       Supervisor    @relation(fields: [supervisorId], references: [id])
  /// Denormalized zone — scope key for COORDINADOR filter
  zoneId           String
  horasExtra       Decimal       @db.Decimal(5, 2)
  motivo           String?
  status           NovedadStatus @default(PENDING)
  clientRef        String?       @unique // optional idempotency token for offline sync
  approvedByUserId String?
  approvedBy       User?         @relation("NovedadApprover", fields: [approvedByUserId], references: [id])
  decidedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // No @@unique([attendanceId]) — partial unique index added by hand in migration:
  // CREATE UNIQUE INDEX "Novedad_attendanceId_active_key"
  //   ON "Novedad"("attendanceId")
  //   WHERE status IN ('PENDING', 'APPROVED');
  @@index([supervisorId])
  @@index([zoneId])
  @@index([status])
  @@index([updatedAt])
}

// ---------------------------------------------------------------------------
// Compensacion de Horas domain — PR-A
// ---------------------------------------------------------------------------

/// Company-wide effective-dated work-day baseline (append-only).
/// Lowering the journey = INSERT a new row with a future vigenteDesde — NEVER UPDATE.
/// Resolving jornadaDelDia: latest JornadaPolicy with vigenteDesde <= attendance.date.
model JornadaPolicy {
  id           String   @id @default(uuid())
  horasDiarias Decimal  @db.Decimal(4, 2)
  vigenteDesde DateTime
  createdAt    DateTime @default(now())

  @@index([vigenteDesde])
}

// ---------------------------------------------------------------------------
// Compensacion de Horas domain — PR-B
// ---------------------------------------------------------------------------

/// Disposition decision when closing a negative-balance period.
/// CARRY_OVER  = roll negative saldo into next period's carryIn.
/// PAYROLL_DEDUCTION = deduct from payroll (debt settled; NOT carried forward).
enum CompensationDisposition {
  CARRY_OVER
  PAYROLL_DEDUCTION
}

/// Immutable snapshot of a closed fortnight balance.
/// Written ONCE at fortnight close — never updated. Mirror of Attendance.completedAt immutability.
/// Uniqueness: one period per operario+periodKey enforced by a partial unique index
/// hand-authored in the migration SQL (Novedad pattern).
model CompensationPeriod {
  id               String                  @id @default(uuid())
  operarioId       String
  operario         Operario                @relation(fields: [operarioId], references: [id])
  /// Denormalized zone for COORDINADOR scope filtering (same pattern as Attendance.zoneId)
  zoneId           String
  /// Denormalized supervisor for SUPERVISOR scope filtering
  supervisorId     String
  /// Canonical fortnight id: "YYYY-MM-Q1" (days 1-15) | "YYYY-MM-Q2" (days 16-end)
  periodKey        String
  desde            String                  // YYYY-MM-DD Colombia local (inclusive)
  hasta            String                  // YYYY-MM-DD Colombia local (inclusive)
  creditos         Decimal                 @db.Decimal(7, 2) // Σ positive deltas
  debitos          Decimal                 @db.Decimal(7, 2) // Σ |negative deltas|
  carryIn          Decimal                 @db.Decimal(7, 2) // negative saldo from previous CARRY_OVER (≤ 0)
  saldo            Decimal                 @db.Decimal(7, 2) // carryIn + creditos - debitos
  disposition      CompensationDisposition?                  // null until decided at close
  approvedByUserId String?                                   // who decided (audit trail)
  approvedBy       User?                   @relation("CompensationApprover", fields: [approvedByUserId], references: [id])
  decidedAt        DateTime?
  closedAt         DateTime                @default(now())   // immutability lock (mirrors completedAt)
  clientRef        String?                 @unique           // idempotency token for close replay
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  // No @@unique([operarioId, periodKey]) — partial unique index added by hand in migration:
  // CREATE UNIQUE INDEX "CompensationPeriod_operario_period_key"
  //   ON "CompensationPeriod"("operarioId","periodKey");
  @@index([operarioId])
  @@index([zoneId])
  @@index([supervisorId])
  @@index([periodKey])
}

/// Device session for soft revocation and refresh token storage.
model DeviceSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  /// Client-provided stable device identifier
  deviceId         String
  deviceLabel      String?
  /// Argon2-hashed refresh token — never plaintext
  refreshTokenHash String
  /// Non-null = revoked (soft revoke preserves audit trail)
  revokedAt        DateTime?
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  /// FCM / APNs push token. Null = device not registered for push notifications.
  pushToken    String?
  /// Device platform hint: "android" | "ios" | "web". Null = unspecified.
  pushPlatform String?

  /// Re-registration of the same device upserts on this key
  @@unique([userId, deviceId])
}
